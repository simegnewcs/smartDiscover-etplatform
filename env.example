# ==========================================
# HelloET Environment Variables
# ==========================================

# Database (MySQL) - Required
# Format: mysql://username:password@host:port/database
# For Vercel, use a hosted MySQL provider (PlanetScale, AWS RDS, etc.)
DATABASE_URL="mysql://username:password@host:port/helloet"

# NextAuth Configuration - Required
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"
# For Vercel production, set to your domain:
# NEXTAUTH_URL="https://your-app.vercel.app"

# File Upload Configuration - Optional
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE=5242880

# ==========================================
# Production Notes
# ==========================================
# 1. Set these variables in Vercel Dashboard
# 2. Ensure NEXTAUTH_SECRET is at least 32 characters
# 3. Use a production MySQL database with SSL
# 4. For images, consider using S3/Cloudinary in production
# ==========================================
